{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Reiken Workspace",
  "version": "1.2.0",
  "identifier": "com.reiken.workspace",
  "build": {
    "frontendDist": "../web",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Reiken Workspace",
        "width": 1280,
        "height": 720,
        "minWidth": 1000,
        "minHeight": 600,
        "maximized": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; connect-src 'self' https://*.supabase.co https://raw.githubusercontent.com https://api.cloudinary.com; img-src 'self' data: https:; media-src 'self' https:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "targets": ["msi", "dmg"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQxNjg2MDA5NjQ0ODU3RjcKUldUM1YwaGtDV0JvMGNwb1JVeW51dHJLOEsreUd3UVhUc3J5QWdiTlQwakY3QUNsN1Y2NncxUEEK",
      "endpoints": [
        "https://raw.githubusercontent.com/rabikasuloa/ReikenWorkspace/main/manifest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
